# Database Configuration
DB_URI=sqlite:///rettlockinfo.db

# TTLock API Configuration
TTLOCK_CLIENT_ID=your_client_id_here
TTLOCK_CLIENT_SECRET=your_client_secret_here
TTLOCK_BASE_URL=https://euapi.ttlock.com/v3

# Tuya API Configuration
TUYA_CLIENT_ID=your_client_id_here
TUYA_CLIENT_SECRET=your_client_secret_here
TUYA_BASE_URL=https://openapi.tuyaeu.com

# Security Configuration
SECRET_KEY=your_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Logging Configuration
LOG_LEVEL=INFO
